NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# reCAPTCHA v2 "I'm not a robot" site key (public — safe to expose in the browser).
# Create a v2 key at https://www.google.com/recaptcha/admin
#   → Choose "reCAPTCHA v2" → "I'm not a robot" Checkbox
#   → Add localhost to allowed domains for dev testing
# When set, the checkbox widget (with image challenge) is shown on the Register tab.
# Leave blank to disable reCAPTCHA entirely (no protection).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
